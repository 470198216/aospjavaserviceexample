android_app {
    name: "WwjSimpleService",
    srcs: [
        "src/main/java/com/example/simpleservice/WwjSimpleService.java",
    ],
    manifest: "src/main/AndroidManifest.xml",
    resource_dirs: ["src/main/res"],
    sdk_version: "current",
    certificate: "platform",
    platform_apis: true,
    dex_preopt: {
        enabled: true,
    },
    installable: true,
}
